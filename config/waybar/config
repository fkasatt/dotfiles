{
    "modules-left": [
        "sway/workspaces", 
//		"custom/media",
		"sway/mode"
    ],
    "modules-center": [
        "clock"
    ],
    "modules-right": [
        "idle_inhibitor", 
        "cpu", 
        "network", 
        "pulseaudio", 
		"backlight",
		"battery",
        "tray"
    ],
    
    "clock": {
        "interval": 1,
        "format": "{:%m/%d %H:%M}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "format-alt": "{:%Y-%m-%d}"
    },
    "custom/media": {
        "format": "{icon} {}",
        "return-type": "json",
        "signal": 15,
        "max-length": 40,
        "format-icons": {
            "spotify": "ΎΗ╝",
            "spotifyd": "ΎΗ╝",
            "default": "ΎΖς"
        },
        "escape": true,
        "on-click": "playerctl play-pause",
        "exec": "$XDG_CONFIG_HOME/waybar/mediaplayer.sh"
    },
    "sway/workspaces": {
        "persistent_workspaces": {
            "1": [],
            "2": [],
            "3": [],
            "4": [],
            "5": [],
        },
        "all-outputs": true,
        "active-only": false,
        "format": "{icon}",
        "format-icons": {
            "1": "ΌαΩ",
            "2": "ΎΕι",
            "3": "ΎΓυ",
			"4": "≤▒ΦΩ",
			"5": "Όυε",
			"6": "6",
			"7": "7",
			"8": "8",
			"9": "9",
            "urgent": "ΎΒς",
            "default": "",
        }
    },

    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "ΎΒχ",
            "deactivated": "ΎΒ░"
        }
    },
    "cpu": {
        "interval": 5,
        "format": "{usage}% ΎΤ╝",
        "format-alt": "{avg_frequency}/{max_frequency}G ≤░Ν┐",
        "tooltip": true
    },

    "network": {
        "interface": "wl*",
        "format-ethernet": "{ifname} ≤░ΙΑ",
        "format-wifi": "{signalStrength}% ΎΑΤ",
        "format-linked": "{ifname} (No IP) ΌτΡ",
        "format-disconnected": "Disconnected έγι",
        "format-alt": "",
        "tooltip-format": "{ifname}: {ipaddr}/{cidr}\n{essid}",
        "interval": 1
    },

    "pulseaudio": {
        "format": "{volume}% {icon}",
        "format-bluetooth": "{volume}% {icon}ΎΛΦ {format_source}",
        "format-bluetooth-muted": "Όυν {icon}ΎΛΦ {format_source}",
        "format-muted": "Όυν",
        "format-icons": {
            "headphone": "ΎΑξ",
            "hands-free": "≤░ΜΟ",
            "headset": "≤░ΜΟ",
            "phone": "ΎΓΧ",
            "portable": "ΎΓΧ",
            "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
        },
        "on-click": "pavucontrol"
    },

    "backlight": {
        "format": "{percent}% {icon}",
        "format-icons": ["≤▒σΟ", "≤▒σΠ", "≤▒σΡ", "≤▒σΣ", "≤▒σΤ", "≤▒σΥ", "≤▒σΦ", "≤▒σΧ", "≤▒σΨ", "≤░δρ"]
    },

    "battery": {
        "states": {
            "warning": 20,
            "critical": 10
        },
        "format": "{capacity}% {icon}",
        "format-charing": "{capacity}% ≤░ΓΕ",
        "format-plugged": "{capacity}% ΎΘο",
        "format-alt": "{time} {icon}",
        "format-icons": ["ΎΚΕ ", "ΎΚΔ ", "ΎΚΓ ", "ΎΚΒ ", "ΎΚΑ "]
    },
}
